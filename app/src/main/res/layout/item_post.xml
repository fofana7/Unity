<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/dark_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/rounded_accent_purple" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPostAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Utilisateur"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPostHandle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\@handle · 1 min"
                    android:textColor="@color/dark_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_more"
                app:tint="@color/dark_text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPostContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ceci est un exemple de post sur mobile."
            android:textColor="@color/dark_text_primary"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp" />

        <ImageView
            android:id="@+id/ivPostImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <!-- File Attachment View -->
        <LinearLayout
            android:id="@+id/llFileAttachment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/sidebar_card_bg"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivFileIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_save"
                app:tint="@color/accent_blue" />

            <TextView
                android:id="@+id/tvFileNamePost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/dark_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:ellipsize="middle"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@android:drawable/btn_star_big_off"
                android:drawablePadding="4dp"
                android:text="0"
                android:textColor="@color/dark_text_secondary"
                android:textSize="12sp"
                app:drawableTint="@color/dark_text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:drawableStart="@android:drawable/ic_menu_send"
                android:drawablePadding="4dp"
                android:text="Répondre"
                android:textColor="@color/dark_text_secondary"
                android:textSize="12sp"
                app:drawableTint="@color/dark_text_secondary" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>