<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modifier les informations"
            android:textColor="@color/unity_muted"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etEditTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titre"
            android:inputType="textCapSentences"
            android:textColor="@color/black" />

        <EditText
            android:id="@+id/etEditType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Type (Examen, Contrôle, etc.)"
            android:inputType="textCapSentences"
            android:textColor="@color/black" />

        <EditText
            android:id="@+id/etEditClasse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Classe (ex: A1MSI)"
            android:inputType="textCapCharacters"
            android:textColor="@color/black" />

        <EditText
            android:id="@+id/etEditDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Date (AAAA-MM-JJ)"
            android:inputType="date"
            android:textColor="@color/black" />

        <EditText
            android:id="@+id/etEditDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Description (optionnel)"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:textColor="@color/black" />

    </LinearLayout>
</ScrollView>
